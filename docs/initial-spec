## Database Schema (SQLite)

### Table: `cities`

```sql
CREATE TABLE cities (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT UNIQUE NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
```

### Table: `hashtags`

```sql
CREATE TABLE hashtags (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    city_id INTEGER NOT NULL REFERENCES cities(id),
    tag TEXT NOT NULL,
    platform TEXT NOT NULL CHECK(platform IN ('tiktok', 'instagram')),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(city_id, tag, platform)
);
```

### Table: `raw_posts`

```sql
CREATE TABLE raw_posts (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    city_id INTEGER NOT NULL REFERENCES cities(id),
    platform TEXT NOT NULL CHECK(platform IN ('tiktok', 'instagram')),
    post_id TEXT NOT NULL,
    hashtag TEXT NOT NULL,
    caption TEXT,
    likes INTEGER DEFAULT 0,
    comments INTEGER DEFAULT 0,
    shares INTEGER DEFAULT 0,
    saves INTEGER DEFAULT 0,
    views INTEGER DEFAULT 0,
    url TEXT,
    author TEXT,
    created_at TIMESTAMP,
    scraped_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    processed BOOLEAN DEFAULT FALSE,
    UNIQUE(platform, post_id)
);
```

### Table: `places`

```sql
CREATE TABLE places (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    city_id INTEGER NOT NULL REFERENCES cities(id),
    name TEXT NOT NULL,
    type TEXT NOT NULL CHECK(type IN ('restaurant', 'cafe', 'bar', 'club', 'market', 'neighborhood', 'viewpoint', 'park', 'museum', 'gallery', 'shop', 'activity', 'street', 'other')),
    mention_count INTEGER DEFAULT 1,
    virality_score REAL DEFAULT 0.0,
    is_tourist_trap BOOLEAN DEFAULT FALSE,
    sample_caption TEXT,
    source_post_ids TEXT, -- JSON array of raw_post IDs
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(city_id, name)
);
```

